[tools]
{%- if use_semantic_release %}
node = "25.8.0"
{%- endif %}
terraform = "{{ terraform_min_version }}"
{%- if use_trivy %}
trivy = "0.69.3"
{%- endif %}
{%- if use_tflint %}
tflint = "0.61.0"
{%- endif %}
{%- if use_terraform_docs %}
terraform-docs = "0.21.0"
{%- endif %}
{%- if use_pre_commit %}
pre-commit = "4.5.1"
{%- endif %}

[tasks.validate]
description = "Validate Terraform configuration"
run = "terraform fmt -check -recursive && terraform validate{% if use_tflint %} && tflint{% endif %}"

[tasks.format]
description = "Format Terraform files"
run = "terraform fmt -recursive"
{% if use_terraform_docs %}
[tasks.docs]
description = "Generate Terraform documentation"
run = "terraform-docs markdown table --output-file=README.md --output-mode=inject ."
{% endif %}
{%- if use_pre_commit %}
[tasks.lint]
description = "Lint all files with pre-commit"
run = "pre-commit run -a"
{% endif %}
[env]
_.file = ".env.example"
