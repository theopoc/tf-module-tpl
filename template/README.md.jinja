## Usage

```hcl
module "{{ module_name | replace('-', '_') }}" {
  {%- if ci_provider == 'github' %}
  source  = "{{ github_repo }}"
  {%- elif ci_provider == 'gitlab' %}
  source  = "{{ gitlab_repo }}"
  {%- endif %}
  version = "~> 1.0"

  name = "example"
  tags = {
    Environment = "dev"
    Terraform   = "true"
  }
}
```

