workflow:
  rules:
    # Pas de pipeline si c'est un tag (on déploie via autre workflow)
    - if: '$CI_COMMIT_TAG'
      when: never
    # Pas de pipeline si la branche a une MR ouverte
    # (le pipeline MR suffit)
    - if: '$CI_COMMIT_BRANCH && $CI_OPEN_MERGE_REQUESTS'
      when: never
    # Pour les merge requests
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    # Pour les pushs sur les branches
    - if: '$CI_COMMIT_BRANCH'

stages:
  - lint
  - docs
  - release

# --- .pre : install tools via mise and share as artifact ---
.mise-cache: &mise-cache
  key:
    prefix: mise-
    files: ["mise.toml"]
  paths:
    - .mise/installs
    - .mise/shims

mise-install:
  stage: .pre
  image:
    name: ghcr.io/jdx/mise:latest
    entrypoint: [""]
  variables:
    MISE_DATA_DIR: $CI_PROJECT_DIR/.mise
  cache:
    - <<: *mise-cache
      policy: push
  script:
    - mise install -q

# --- Hidden job : base for all mise-managed tools ---

.mise-base:
  image:
    name: ghcr.io/jdx/mise:latest
    entrypoint: [""]
  variables:
    MISE_DATA_DIR: $CI_PROJECT_DIR/.mise
  cache:
    - <<: *mise-cache
      policy: pull



# --- STAGE: lint ---

tf-fmt:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- terraform fmt -check -recursive
{%- if use_tflint %}

tflint:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- tflint --init
    - mise exec -- tflint
{%- endif %}

{%- if use_trivy %}

trivy:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- trivy config .
{%- endif %}

# --- STAGE: validate ---

tf-validate:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- terraform init -backend=false
    - mise exec -- terraform validate
{%- if use_terraform_docs %}

# --- STAGE: docs ---

tf-docs:
  extends: .mise-base
  stage: docs
  script:
    - mise exec -- terraform-docs --output-check .
  needs: []

{%- endif %}
{%- if use_semantic_release %}

# --- STAGE: release ---

release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
{%- endif %}
