stages:
  - lint
  - validate
  - docs
  - release

# --- .pre : install tools via mise and share as artifact ---

mise-install:
  stage: .pre
  image: ghcr.io/jdx/mise:latest
  variables:
    MISE_DATA_DIR: ${CI_PROJECT_DIR}/.mise-data
  script:
    - mise install
    - mise ls
  artifacts:
    paths:
      - .mise-data/installs

# --- Hidden job : base for all mise-managed tools ---

.mise-base:
  image: ghcr.io/jdx/mise:latest
  variables:
    MISE_DATA_DIR: ${CI_PROJECT_DIR}/.mise-data
  needs:
    - job: mise-install
      artifacts: true
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'

# --- STAGE: lint ---

tf-fmt:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- terraform fmt -check -recursive
{%- if use_tflint %}

tflint:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- tflint --init
    - mise exec -- tflint
{%- endif %}

trivy:
  stage: lint
  image: docker.io/aquasec/trivy:latest
  script:
    - trivy config .
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'

# --- STAGE: validate ---

tf-validate:
  extends: .mise-base
  stage: validate
  script:
    - mise exec -- terraform init -backend=false
    - mise exec -- terraform validate
{%- if use_terraform_docs %}

# --- STAGE: docs ---

tf-docs:
  extends: .mise-base
  stage: docs
  script:
    - mise exec -- terraform-docs diff . --output-check
{%- endif %}
{%- if use_semantic_release %}

# --- STAGE: release ---

release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
{%- endif %}
