workflow:
  rules:
    # Pas de pipeline si c'est un tag (on déploie via autre workflow)
    - if: '$CI_COMMIT_TAG'
      when: never
    # Pas de pipeline si la branche a une MR ouverte
    # (le pipeline MR suffit)
    - if: '$CI_COMMIT_BRANCH && $CI_OPEN_MERGE_REQUESTS'
      when: never
    # Pour les merge requests
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    # Pour les pushs sur les branches
    - if: '$CI_COMMIT_BRANCH'

stages:
  - lint
  - docs
  - release

# --- .pre : install tools via mise and share as artifact ---
.mise-cache: &mise-cache
  key:
    prefix: mise-
    files: ["mise.toml"]
  paths:
    - .mise/installs
    - .mise/shims

parse-mise-versions:
  stage: .pre
  image: alpine:latest
  script:
    - |
      # Parse la section [tools] du mise.toml et génère le dotenv
      awk '
        /^\[tools\]/ { in_tools=1; next }
        /^\[/        { in_tools=0 }
        in_tools && /=/ {
          gsub(/[ \t"'\'']/, "")
          split($0, a, "=")
          tool = toupper(a[1])
          gsub(/-/, "_", tool)
          version = a[2]
          print "MISE_" tool "_VERSION=" version
        }
      ' mise.toml > mise.env
      cat mise.env
  artifacts:
    reports:
      dotenv: mise.env

# --- Hidden job : base for all mise-managed tools ---

.mise-base:
  image:
    name: ghcr.io/jdx/mise:latest
    entrypoint: [""]
  variables:
    MISE_DATA_DIR: $CI_PROJECT_DIR/.mise
  cache:
    - <<: *mise-cache
      policy: pull



# --- STAGE: lint ---

tf-fmt:
  image: hashicorp/terraform:{{ terraform_min_version }}
  stage: lint
  script:
    - terraform fmt -check -recursive
{%- if use_tflint %}

tflint:
  image: ghcr.io/terraform-linters/tflint:v0.61.0
  stage: lint
  script:
    - tflint --init
    - tflint
{%- endif %}

{%- if use_trivy %}

trivy:
image: aquasec/trivy:0.69.3
  stage: lint
  script:
    - trivy config .
{%- endif %}

# --- STAGE: validate ---

tf-validate:
  image: hashicorp/terraform:{{ terraform_min_version }}
  stage: lint
  script:
    - terraform init -backend=false
    - terraform validate
{%- if use_terraform_docs %}

# --- STAGE: docs ---

tf-docs:
  image: quay.io/terraform-docs/terraform-docs:0.21.0
  stage: docs
  script:
    - terraform-docs --output-check .
  needs: []

{%- endif %}
{%- if use_semantic_release %}

# --- STAGE: release ---

release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
{%- endif %}
