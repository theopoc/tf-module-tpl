stages:
  - lint
{%- if use_semantic_release %}
  - release
{%- endif %}

variables:
  FF_USE_FASTZIP: "true"
  ARTIFACT_COMPRESSION_LEVEL: "fastest"

lint:
  stage: lint
  image:
    name: hashicorp/terraform:latest
    entrypoint: [""]
{%- if use_tflint %}
  before_script:
    - apk add --no-cache curl
    - curl -s https://raw.githubusercontent.com/terraform-linters/tflint/master/install_linux.sh | sh
{%- endif %}
  script:
    - terraform fmt -check -recursive
    - terraform init -backend=false
    - terraform validate
{%- if use_tflint %}
    - tflint --init
    - tflint
{%- endif %}
  only:
    - merge_requests
    - main
{% if use_semantic_release %}
release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  only:
    - main
  needs:
    - lint
{%- endif %}
