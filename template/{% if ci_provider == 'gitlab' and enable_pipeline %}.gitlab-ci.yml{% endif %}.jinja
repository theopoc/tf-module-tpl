stages:
  - lint
  - docs
  - release

# --- .pre : install tools via mise and share as artifact ---
.mise-cache: &mise-cache
  key:
    prefix: mise-
    files: ["mise.toml", "./bin/mise"]
  paths:
    - .mise/installs
    - .mise/mise-2025.1.3

mise-install:
  stage: .pre
  image:
    name: ghcr.io/jdx/mise:latest
    entrypoint: [""]
  variables:
    MISE_DATA_DIR: $CI_PROJECT_DIR/.mise/mise-data
  cache:
    - key:
        prefix: mise-
        files:
          - .mise.toml
      paths:
        - $MISE_DATA_DIR
  script:
    - mise install -q

# --- Hidden job : base for all mise-managed tools ---



# --- STAGE: lint ---

tf-fmt:
  cache:
    - <<: *mise-cache
      policy: pull-push
  stage: lint
  script:
    - mise exec -- terraform fmt -check -recursive
{%- if use_tflint %}

tflint:
  cache:
    - <<: *mise-cache
      policy: pull-push
  stage: lint
  script:
    - mise exec -- tflint --init
    - mise exec -- tflint
{%- endif %}

{%- if use_trivy %}

trivy:
  cache:
    - <<: *mise-cache
      policy: pull-push
  stage: lint
  script:
    - mise exec -- trivy config .
{%- endif %}

# --- STAGE: validate ---

tf-validate:
  cache:
    - <<: *mise-cache
      policy: pull-push
  stage: lint
  script:
    - mise exec -- terraform init -backend=false
    - mise exec -- terraform validate
{%- if use_terraform_docs %}

# --- STAGE: docs ---

tf-docs:
  cache:
    - <<: *mise-cache
      policy: pull-push
  stage: docs
  script:
    - mise exec -- terraform-docs --output-check .
  needs: []
{%- endif %}
{%- if use_semantic_release %}

# --- STAGE: release ---

release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
{%- endif %}
