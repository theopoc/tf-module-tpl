stages:
  - lint
  - docs
  - release

# --- .pre : install tools via mise and share as artifact ---

mise-install:
  stage: .pre
  image:
    name: ghcr.io/jdx/mise:latest
    entrypoint: [""]
  variables:
    MISE_DATA_DIR: ${CI_PROJECT_DIR}/.mise/mise-data
  cache:
    - key:
        prefix: mise-
        files:
          - .mise.toml
      paths:
        - .mise/mise-data
  script:
    - mise install
    - mise ls
  artifacts:
    paths:
      - .mise/mise-data/installs

# --- Hidden job : base for all mise-managed tools ---

.mise-base:
  image:
    name: ghcr.io/jdx/mise:latest
    entrypoint: [""]
  variables:
    MISE_DATA_DIR: ${CI_PROJECT_DIR}/.mise/mise-data
  needs:
    - job: mise-install
      artifacts: true
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'

# --- STAGE: lint ---

tf-fmt:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- terraform fmt -check -recursive
{%- if use_tflint %}

tflint:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- tflint --init
    - mise exec -- tflint
{%- endif %}

{%- if use_trivy %}

trivy:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- trivy config .
{%- endif %}

# --- STAGE: validate ---

tf-validate:
  extends: .mise-base
  stage: lint
  script:
    - mise exec -- terraform init -backend=false
    - mise exec -- terraform validate
{%- if use_terraform_docs %}

# --- STAGE: docs ---

tf-docs:
  extends: .mise-base
  stage: docs
  script:
    - mise exec -- terraform-docs --output-check .
  needs:
    - tf-validate
{%- endif %}
{%- if use_semantic_release %}

# --- STAGE: release ---

release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
{%- endif %}
