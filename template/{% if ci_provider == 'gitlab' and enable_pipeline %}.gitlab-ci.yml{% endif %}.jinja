workflow:
  rules:
    # Pas de pipeline si c'est un tag (on déploie via autre workflow)
    - if: '$CI_COMMIT_TAG'
      when: never
    # Pas de pipeline si la branche a une MR ouverte
    # (le pipeline MR suffit)
    - if: '$CI_COMMIT_BRANCH && $CI_OPEN_MERGE_REQUESTS'
      when: never
    # Pour les merge requests
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    # Pour les pushs sur les branches
    - if: '$CI_COMMIT_BRANCH'

stages:
  - lint
  - docs
  - release


parse-mise-versions:
  stage: .pre
  image: alpine:latest
  script:
    - |
      # Parse la section [tools] du mise.toml et génère le dotenv
      awk '
        /^\[tools\]/ { in_tools=1; next }
        /^\[/        { in_tools=0 }
        in_tools && /=/ {
          gsub(/[ \t"'\'']/, "")
          split($0, a, "=")
          tool = toupper(a[1])
          gsub(/-/, "_", tool)
          version = a[2]
          print "MISE_" tool "_VERSION=" version
        }
      ' .mise.toml > mise.env
      cat mise.env
  artifacts:
    reports:
      dotenv: mise.env

# --- STAGE: lint ---

tf-fmt:
  image:
    name: hashicorp/terraform:{{ terraform_min_version }}
    entrypoint: [""]
  stage: lint
  script:
    - terraform fmt -check -recursive -write=false -diff
  needs:
    - job: parse-mise-versions
      artifacts: true
{%- if use_tflint %}

tflint:
  image:
    name: ghcr.io/terraform-linters/tflint:v$MISE_TFLINT_VERSION
    entrypoint: [""]
  stage: lint
  script:
    - tflint --init
    - tflint --recursive
  needs:
    - job: parse-mise-versions
      artifacts: true
{%- endif %}

{%- if use_trivy %}

trivy:
  image:
    name: aquasec/trivy:$MISE_TRIVY_VERSION
    entrypoint: [""]
  stage: lint
  script:
    - trivy config .
  needs:
    - job: parse-mise-versions
      artifacts: true
{%- endif %}

# --- STAGE: validate ---

tf-validate:
  image:
    name: hashicorp/terraform:{{ terraform_min_version }}
    entrypoint: [""]
  stage: lint
  script:
    - terraform init -backend=false
    - terraform validate
  needs:
    - job: parse-mise-versions
      artifacts: true
{%- if use_terraform_docs %}

# --- STAGE: docs ---

tf-docs:
  image:
    name: quay.io/terraform-docs/terraform-docs:$MISE_TERRAFORM_DOCS_VERSION
    entrypoint: [""]
  stage: docs
  script:
    - terraform-docs --output-check .
  needs:
    - job: parse-mise-versions
      artifacts: true

{%- endif %}
{%- if use_semantic_release %}

# --- STAGE: release ---

release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  cache:
    policy: pull-push
    paths:
      - node_modules/
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
{%- endif %}
