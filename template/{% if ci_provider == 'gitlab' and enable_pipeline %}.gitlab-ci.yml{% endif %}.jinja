stages:
  - lint
{%- if use_semantic_release %}
  - release
{%- endif %}

variables:
  FF_USE_FASTZIP: "true"
  ARTIFACT_COMPRESSION_LEVEL: "fastest"

lint:
  stage: lint
  image: alpine:latest
  before_script:
    - apk add --no-cache terraform{% if use_tflint %} tflint{% endif %}

  script:
    - terraform fmt -check -recursive
    - terraform init -backend=false
    - terraform validate
{%- if use_tflint %}
    - tflint --init
    - tflint
{%- endif %}
  only:
    - merge_requests
    - main
{% if use_semantic_release %}
release:
  stage: release
  image: node:lts
  before_script:
    - npm ci
  script:
    - npx semantic-release
  only:
    - main
  needs:
    - lint
{%- endif %}
