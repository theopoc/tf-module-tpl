{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "semanticCommits": "enabled",
  "semanticCommitType": "fix",
  "platformAutomerge": true,
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Disable all npm non-security updates",
      "matchManagers": ["npm"],
      "enabled": false
    },
    {
      "description": "Automerge mise tool updates when CI passes",
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "description": "Automerge GitHub Actions minor and patch updates when CI passes",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "description": "Automerge uv dependency minor and patch updates when CI passes",
      "matchManagers": ["uv"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "description": "Automerge tflint-ruleset-aws minor and patch updates when CI passes",
      "matchPackageNames": ["terraform-linters/tflint-ruleset-aws"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeStrategy": "squash"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["tflint = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform-linters/tflint",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["trivy = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["terraform-docs = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform-docs/terraform-docs",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["pre-commit = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "pre-commit",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^copier\\.yml$"],
      "matchStrings": ["terraform_min_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform",
      "datasourceTemplate": "hashicorp",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^copier\\.yml$"],
      "matchStrings": ["aws_provider_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "hashicorp/aws",
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp"
    },
    {
      "customType": "regex",
      "fileMatch": ["^copier\\.yml$"],
      "matchStrings": ["awscc_provider_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "hashicorp/awscc",
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\{%.*use_tflint.*%\\}\\.tflint\\.hcl\\{%.*%\\}\\.jinja$"],
      "matchStrings": ["plugin \"aws\" \\{[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform-linters/tflint-ruleset-aws",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
