{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "minimumReleaseAge": "7 days",
  "prConcurrentLimit": 5,
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "minimumReleaseAge": "7 days"
  },
  "packageRules": [
    {
      "description": "Disable all npm non-security updates",
      "matchManagers": ["npm"],
      "enabled": false
    },
    {
      "description": "Automerge minor and patch updates for tracked managers when CI passes",
      "matchManagers": ["custom.regex", "github-actions", "uv"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Automerge Terraform, providers, and tflint-ruleset-aws minor and patch updates when CI passes",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["terraform", "hashicorp/aws", "hashicorp/awscc", "terraform-linters/tflint-ruleset-aws"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Group all mise tool updates into a single PR",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": [
        "terraform-linters/tflint",
        "aquasecurity/trivy",
        "quay.io/terraform-docs/terraform-docs",
        "pre-commit"
      ],
      "groupName": "mise tools"
    },
    {
      "description": "Group GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["tflint = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform-linters/tflint",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["trivy = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["terraform-docs = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "quay.io/terraform-docs/terraform-docs",
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\.mise\\.toml\\.jinja$"],
      "matchStrings": ["pre-commit = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "pre-commit",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^copier\\.yml$"],
      "matchStrings": ["terraform_min_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform",
      "datasourceTemplate": "hashicorp",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^copier\\.yml$"],
      "matchStrings": ["aws_provider_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "hashicorp/aws",
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp"
    },
    {
      "customType": "regex",
      "fileMatch": ["^copier\\.yml$"],
      "matchStrings": ["awscc_provider_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "hashicorp/awscc",
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp"
    },
    {
      "customType": "regex",
      "fileMatch": ["template/\\{%.*use_tflint.*%\\}\\.tflint\\.hcl\\{%.*%\\}\\.jinja$"],
      "matchStrings": ["plugin \"aws\" \\{[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "terraform-linters/tflint-ruleset-aws",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
