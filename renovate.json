{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "minimumReleaseAge": "7 days",
  "schedule": ["at any time"],
  "prConcurrentLimit": 5,
  "labels": [
    "dependencies"
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Disable all npm non-security updates",
      "matchManagers": [
        "npm"
      ],
      "enabled": false
    },
    {
      "description": "Automerge minor and patch updates for tracked managers when CI passes",
      "matchManagers": [
        "custom.regex",
        "github-actions",
        "uv"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Disable digest pinning for terraform-docs (target file is not a Dockerfile)",
      "matchPackageNames": [
        "quay.io/terraform-docs/terraform-docs"
      ],
      "pinDigests": false
    },
    {
      "description": "Group all mise tool updates into a single PR",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "node",
        "terraform-linters/tflint",
        "aquasecurity/trivy",
        "quay.io/terraform-docs/terraform-docs",
        "pre-commit"
      ],
      "groupName": "mise tools"
    },
    {
      "description": "Group GitHub Actions updates into a single PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/template/\\.mise\\.toml\\.jinja$/"
      ],
      "matchStrings": [
        "node = \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/template/\\.mise\\.toml\\.jinja$/"
      ],
      "matchStrings": [
        "tflint = \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "terraform-linters/tflint",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/template/\\.mise\\.toml\\.jinja$/"
      ],
      "matchStrings": [
        "trivy = \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/template/\\.mise\\.toml\\.jinja$/"
      ],
      "matchStrings": [
        "terraform-docs = \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "quay.io/terraform-docs/terraform-docs",
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/template/\\.mise\\.toml\\.jinja$/"
      ],
      "matchStrings": [
        "pre-commit = \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "pre-commit",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^copier\\.yml$/"
      ],
      "matchStrings": [
        "terraform_min_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "terraform",
      "datasourceTemplate": "hashicorp",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^copier\\.yml$/"
      ],
      "matchStrings": [
        "aws_provider_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "hashicorp/aws",
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^copier\\.yml$/"
      ],
      "matchStrings": [
        "awscc_provider_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "hashicorp/awscc",
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/template/\\{%.*use_tflint.*%\\}\\.tflint\\.hcl\\{%.*%\\}\\.jinja$/"
      ],
      "matchStrings": [
        "plugin \"aws\" \\{[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "terraform-linters/tflint-ruleset-aws",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
